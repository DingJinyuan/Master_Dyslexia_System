# =============================================================================
# Dyslexia Reader — 环境变量配置
# =============================================================================

# ====== 应用基础 ======
APP_NAME=Dyslexia Reader Backend
APP_ENV=dev
SECRET_KEY=replace-this-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=120

# ====== 数据库 ======
DATABASE_URL=sqlite:///./dyslexia_reader.db

# ====== AI 大模型 — DeepSeek（文本精炼 / 可读性评估 / 摘要） ======
# 申请地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-4544ded25f744a0b8e275af2db927135

# DeepSeek API 地址（也兼容 OpenAI 兼容接口）
DEEPSEEK_API_BASE=https://api.deepseek.com

# 模型 ID
LLM_MODEL_ID=deepseek-v4-flash

# ====== 有道智云 — 划词翻译 + TTS 语音合成 ======
# 申请地址：https://ai.youdao.com/console/
YOUDAO_APP_KEY=79b1f588cbcdede0
YOUDAO_APP_SECRET=oI7qMYHunhcjWoykTurVLQTUgFnXLyBW

# ====== OCR ======
OCR_PROVIDER=mock

# ====== TTS ======
TTS_PROVIDER=mock
TTS_VOICE_ZH=zh-CN-XiaoxiaoNeural
TTS_VOICE_EN=en-US-JennyNeural
TTS_OUTPUT_DIR=storage/audio

# ====== NLP ======
SPACY_EN_MODEL=en_core_web_sm

# ====== 管理员 ======
ADMIN_EMAIL=admin@example.com

# ====== MCP 思维导图 ======
MCP_MINDMAP_TIMEOUT=60
