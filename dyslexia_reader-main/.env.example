# =============================================================================
# Dyslexia Reader — 环境变量配置模板
# =============================================================================
# 复制为 .env 后填入实际值：cp .env.example .env
#
# 标记说明：
#   [必填]  不填则相关功能不可用
#   [推荐]  建议修改默认值
#   [可选]  保留默认值即可
# =============================================================================

# ====== 应用基础 ======

APP_NAME=Dyslexia Reader Backend
APP_ENV=dev

# [推荐] JWT 签名密钥，生成方式：openssl rand -hex 32
SECRET_KEY=replace-this-with-a-long-random-string

ACCESS_TOKEN_EXPIRE_MINUTES=120


# ====== 数据库 ======

# SQLite（开发）
DATABASE_URL=sqlite:///./dyslexia_reader.db
# PostgreSQL（生产）
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/dyslexia_reader


# ====== AI 大模型 — DeepSeek（文本精炼 / 可读性评估 / 摘要） ======
# 申请地址：https://platform.deepseek.com/api_keys
# 登录后点击「创建 API Key」，复制 sk- 开头的字符串

DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# DeepSeek API 地址（也兼容 OpenAI 兼容接口）
DEEPSEEK_API_BASE=https://api.deepseek.com

# 模型 ID
LLM_MODEL_ID=deepseek-v4-flash


# ====== 有道智云 — 划词翻译 + TTS 语音合成 ======
# 申请地址：https://ai.youdao.com/console/
# 登录后进入「应用总览」→「创建应用」，勾选「文本翻译」和「语音合成」
# 创建完成后复制「应用 ID」和「应用密钥」

YOUDAO_APP_KEY=your-youdao-app-key
YOUDAO_APP_SECRET=your-youdao-app-secret


# ====== OCR（文档图片文字识别） ======

# mock = 跳过识别，后续可扩展真实 OCR 服务
OCR_PROVIDER=mock


# ====== TTS 语音合成 ======

# mock = 跳过；留空则自动降级尝试 edge-tts → youdao → gtts → pyttsx3
TTS_PROVIDER=mock

# edge-tts 中文音色
TTS_VOICE_ZH=zh-CN-XiaoxiaoNeural
# edge-tts 英文音色
TTS_VOICE_EN=en-US-JennyNeural

# TTS 音频输出目录
TTS_OUTPUT_DIR=storage/audio


# ====== NLP ======

# spaCy 英文模型，安装：python -m spacy download en_core_web_sm
SPACY_EN_MODEL=en_core_web_sm


# ====== 管理员 ======
ADMIN_EMAIL=admin@example.com


# ====== MCP 思维导图 ======
# markmap-mcp-server 调用超时（秒）
MCP_MINDMAP_TIMEOUT=60
